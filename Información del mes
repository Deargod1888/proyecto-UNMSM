print("--- INFORMACIÓN DEL MES ---")

# Solicitamos el número entero (asumiendo la restricción de natural)
num_mes = int(input("Introduce el número de un mes (1 al 12): "))

# Usamos la estructura MATCH (Equivalente al CASO del pseudocódigo)
match num_mes:
    case 1:
        print("Enero - 31 días")
    case 2:
        print("Febrero - 28 días (o 29 si es bisiesto)")
    case 3:
        print("Marzo - 31 días")
    case 4:
        print("Abril - 30 días")
    case 5:
        print("Mayo - 31 días")
    case 6:
        print("Junio - 30 días")
    case 7:
        print("Julio - 31 días")
    case 8:
        print("Agosto - 31 días")
    case 9:
        print("Septiembre - 30 días")
    case 10:
        print("Octubre - 31 días")
    case 11:
        print("Noviembre - 30 días")
    case 12:
        print("Diciembre - 31 días")
    case _:
        # El guion bajo (_) funciona como el "Otros" o "Default"
        print("Mes inválido")
