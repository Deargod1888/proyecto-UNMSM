# 1. Leer el número de la entrada estándar y convertirlo a entero
numero = int(input("Introduzca un número: "))

# 2. Imprimir el encabezado
print(f"La tabla de multiplicar del {numero} es:")

# 3. Generar la tabla del 1 al 10
for i in range(1, 11):
    resultado = numero * i
    print(f"{numero} x {i} = {resultado}")
